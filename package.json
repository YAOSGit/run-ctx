{
	"name": "@yaos-git/run-ctx",
	"version": "126.0.4",
	"description": "Context-aware command alias CLI — run the right command based on cwd, files, and env vars",
	"main": "dist/cli.js",
	"bin": {
		"run-ctx": "dist/cli.js",
		"rc": "dist/cli.js",
		"run-ctx-editor": "dist/editor-cli.js"
	},
	"files": [
		"dist"
	],
	"scripts": {
		"dev": "run-tui -r \"^dev:\"",
		"dev:typescript": "tsgo --noEmit -p tsconfig.app.json --watch",
		"dev:test": "vitest --watch",
		"build": "node esbuild.config.js",
		"lint": "npm run lint:types && npm run lint:fix && npm run lint:format && npm run lint:audit",
		"lint:check": "biome lint .",
		"lint:fix": "biome check . --write",
		"lint:format": "biome format . --write",
		"lint:types": "tsgo --noEmit -p tsconfig.app.json",
		"lint:audit": "npm audit",
		"test": "npm run test:unit && npm run test:react && npm run test:types && npm run test:e2e",
		"test:unit": "vitest run -c vitest.unit.config.ts",
		"test:react": "vitest run -c vitest.react.config.ts",
		"test:types": "vitest run -c vitest.type.config.ts",
		"test:e2e": "vitest run -c vitest.e2e.config.ts",
		"coverage": "vitest run --coverage",
		"coverage:unit": "vitest run -c vitest.unit.config.ts --coverage",
		"coverage:react": "vitest run -c vitest.react.config.ts --coverage",
		"size": "size-limit",
		"prepublishOnly": "npm run lint:types && npm run lint:check && npm run test:unit && npm run test:react && npm run test:types && npm run test:e2e && npm run lint:audit && npm run build"
	},
	"repository": {
		"type": "git",
		"url": "git+https://github.com/YAOSGit/run-ctx.git"
	},
	"bugs": {
		"url": "https://github.com/YAOSGit/run-ctx/issues"
	},
	"homepage": "https://github.com/YAOSGit/run-ctx#readme",
	"keywords": [
		"cli",
		"alias",
		"context",
		"command-runner",
		"tui",
		"devtools"
	],
	"author": {
		"name": "Ygor de Paula",
		"email": "ygorh.de.paula@gmail.com",
		"url": "https://github.com/YAOSGit/run-ctx"
	},
	"license": "ISC",
	"engines": {
		"node": ">=18.0.0"
	},
	"type": "module",
	"dependencies": {
		"chalk": "^5.6.2",
		"commander": "^14.0.3",
		"omelette": "^0.4.17",
		"picomatch": "^4.0.3",
		"re2": "^1.23.3"
	},
	"devDependencies": {
		"@biomejs/biome": "^2.3.8",
		"@inkjs/ui": "^2.0.0",
		"@size-limit/file": "^11.2.0",
		"@testing-library/dom": "^10.4.1",
		"@testing-library/react": "^16.3.0",
		"@types/node": "^25.0.1",
		"@types/omelette": "^0.4.5",
		"@types/picomatch": "^4.0.2",
		"@types/re2": "^1.10.0",
		"@types/react": "^19.2.7",
		"@typescript/native-preview": "^7.0.0-dev.20251216",
		"@vitest/coverage-v8": "^4.0.15",
		"@yaos-git/run-tui": "^126.0.0",
		"esbuild": "^0.27.1",
		"ink": "^6.5.1",
		"ink-testing-library": "^4.0.0",
		"jsdom": "^27.3.0",
		"node-pty": "^1.0.0",
		"react": "^19.2.3",
		"size-limit": "^11.2.0",
		"strip-ansi": "^7.1.2",
		"typescript": "^5.9.3",
		"vitest": "^4.0.15"
	}
}