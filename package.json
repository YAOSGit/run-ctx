{
	"name": "run-ctx",
	"version": "126.0.0",
	"description": "Context-aware command alias CLI — run the right command based on cwd, files, and env vars",
	"main": "dist/cli.js",
	"bin": {
		"run-ctx": "dist/cli.js",
		"run-ctx-editor": "dist/editor-cli.js"
	},
	"files": [
		"dist"
	],
	"scripts": {
		"dev": "vitest --watch",
		"build": "node esbuild.config.js",
		"lint": "npm run lint:types && npm run lint:fix && npm run lint:format && npm run lint:audit",
		"lint:check": "biome lint .",
		"lint:fix": "biome check . --write",
		"lint:format": "biome format . --write",
		"lint:types": "tsgo --noEmit -p tsconfig.app.json",
		"lint:audit": "npm audit",
		"test": "npm run test:unit && npm run test:react",
		"test:unit": "vitest run -c vitest.unit.config.ts",
		"test:react": "vitest run -c vitest.react.config.ts",
		"prepublishOnly": "npm run lint:types && npm run lint:check && npm run test:unit && npm run test:react && npm run lint:audit && npm run build"
	},
	"repository": {
		"type": "git",
		"url": "git+https://github.com/YAOSGit/run-ctx.git"
	},
	"bugs": {
		"url": "https://github.com/YAOSGit/run-ctx/issues"
	},
	"homepage": "https://github.com/YAOSGit/run-ctx#readme",
	"keywords": [
		"cli",
		"alias",
		"context",
		"command-runner",
		"tui",
		"devtools"
	],
	"author": "Ygor de Paula",
	"email": "ygorh.de.paula@gmail.com",
	"url": "https://github.com/YAOSGit/run-tui",
	"license": "ISC",
	"type": "module",
	"dependencies": {
		"@inkjs/ui": "^2.0.0",
		"chalk": "^5.6.2",
		"commander": "^14.0.2",
		"ink": "^6.5.1",
		"react": "^19.2.3"
	},
	"devDependencies": {
		"@biomejs/biome": "^2.3.8",
		"@testing-library/dom": "^10.4.1",
		"@testing-library/react": "^16.3.0",
		"@types/node": "^25.0.1",
		"@types/react": "^19.2.7",
		"@typescript/native-preview": "^7.0.0-dev.20251216",
		"@vitest/coverage-v8": "^4.0.15",
		"@yaos-git/run-tui": "^125.2.0",
		"esbuild": "^0.27.1",
		"happy-dom": "^20.0.11",
		"ink-testing-library": "^4.0.0",
		"jsdom": "^27.3.0",
		"typescript": "^5.9.3",
		"vitest": "^4.0.15"
	}
}
